rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && request.auth.token.email == "jogonesteterp@gmail.com";
    }

    match /privateKeys/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId || isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && request.auth.uid == userId || isAdmin() ||
        (isAuth() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['contacts']));
      allow delete: if isAdmin();
    }

    match /chats/{chatId} {
      allow read, write: if isAuth() && chatId.matches('.*' + request.auth.uid + '.*');
      match /messages/{messageId} {
        allow read, write, delete: if isAuth() && chatId.matches('.*' + request.auth.uid + '.*');
      }
    }

    match /typing/{chatId} {
      allow read, write: if isAuth();
    }

    match /inviteTokens/{tokenId} {
      allow read: if true;
      allow write: if isAuth();
      allow delete: if isAuth();
    }

    match /groupInviteTokens/{tokenId} {
      allow read: if true;
      allow write: if isAuth();
      allow delete: if isAuth();
    }

    match /rateLimits/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId || isAdmin();
    }

    match /requestCounters/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId || isAdmin();
    }

    match /userBackups/{uniqueCode} {
      allow read, write: if isAuth();
    }

    match /privateKeyBackups/{uniqueCode} {
      allow read, write: if isAuth();
    }

    match /deviceAuth/{fingerprint} {
      allow read, write: if isAuth();
    }

    match /history/{msgId} {
      allow read, write: if isAuth();
    }

    match /groups/{groupId} {
      allow read: if isAuth() && (request.auth.uid in resource.data.members || request.auth.uid == resource.data.adminUid);
      allow create: if isAuth() && request.resource.data.adminUid == request.auth.uid;
      allow update: if isAuth() && (request.auth.uid == resource.data.adminUid || request.auth.uid in resource.data.members);
      allow delete: if isAuth() && resource.data.adminUid == request.auth.uid;

      match /messages/{msgId} {
        allow read, write: if isAuth() && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
        allow delete: if isAuth() && request.auth.uid == resource.data.senderId;
      }
    }

    match /requests/{requestId} {
      allow read: if isAuth() && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid);
      allow create: if isAuth() && request.resource.data.fromUid == request.auth.uid;
      allow update: if isAuth() && (request.auth.uid == resource.data.toUid || request.auth.uid == resource.data.fromUid);
      allow delete: if isAuth() && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid);
    }
  }
}
