rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && request.auth.token.email == "jogonesteterp@gmail.com";
    }

    function canUpdateOwnOrMutualContacts(userId) {
      return (
        isAuth() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['contacts']) &&
        (
          (
            request.resource.data.contacts.hasAll(resource.data.contacts) &&
            request.resource.data.contacts.size() == resource.data.contacts.size() + 1 &&
            request.resource.data.contacts.hasAll([request.auth.uid])
          ) ||
          (
            resource.data.contacts.hasAll(request.resource.data.contacts) &&
            resource.data.contacts.size() == request.resource.data.contacts.size() + 1 &&
            resource.data.contacts.hasAll([request.auth.uid])
          )
        )
      );
    }

    function hasTrustedJoinRequest(groupId) {
      return (
        exists(/databases/$(database)/documents/requests/$(groupId + '_' + request.auth.uid)) &&
        get(/databases/$(database)/documents/requests/$(groupId + '_' + request.auth.uid)).data.type == 'group' &&
        get(/databases/$(database)/documents/requests/$(groupId + '_' + request.auth.uid)).data.status == 'pending' &&
        get(/databases/$(database)/documents/requests/$(groupId + '_' + request.auth.uid)).data.toUid == request.auth.uid &&
        (
          get(/databases/$(database)/documents/requests/$(groupId + '_' + request.auth.uid)).data.fromUid == resource.data.adminUid ||
          get(/databases/$(database)/documents/requests/$(groupId + '_' + request.auth.uid)).data.fromUid in resource.data.members
        )
      );
    }

    match /privateKeys/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId || isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if (isAuth() && request.auth.uid == userId) || isAdmin() || canUpdateOwnOrMutualContacts(userId);
      allow delete: if isAdmin();
    }

    match /chats/{chatId} {
      allow read, write: if isAuth() && (
        chatId.matches('^' + request.auth.uid + '_[^_]+$') ||
        chatId.matches('^[^_]+_' + request.auth.uid + '$')
      );
      match /messages/{messageId} {
        allow read, write, delete: if isAuth() && (
          chatId.matches('^' + request.auth.uid + '_[^_]+$') ||
          chatId.matches('^[^_]+_' + request.auth.uid + '$')
        );
      }
    }

    match /requests/{docId} {
      allow read, write: if isAuth();
    }

    match /requestCounters/{userId} {
      allow read, write: if (isAuth() && request.auth.uid == userId) || isAdmin();
    }

    match /inviteTokens/{tokenId} {
      allow read: if isAuth();
      allow write: if isAuth();
      allow delete: if isAuth();
    }

    match /groupInviteTokens/{tokenId} {
      allow read: if isAuth();
      allow write: if isAuth();
      allow delete: if isAuth();
    }

    match /settings/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    match /userBackups/{uniqueCode} {
      allow read, write: if false;
    }

    match /privateKeyBackups/{uniqueCode} {
      allow read, write: if false;
    }

    match /deviceAuth/{fingerprint} {
      allow read, write: if isAuth();
    }

    match /history/{msgId} {
      allow read, write: if false;
    }

    match /typing/{chatId} {
      allow read, write: if isAuth() && (
        chatId.matches('.*' + request.auth.uid + '.*')
      );
    }

    match /groups/{groupId} {
      allow read: if isAuth() && (request.auth.uid in resource.data.members || request.auth.uid == resource.data.adminUid);
      allow create: if isAuth() && request.resource.data.adminUid == request.auth.uid;
      allow update: if isAuth() && (
        request.auth.uid == resource.data.adminUid ||
        (
          (request.auth.uid in resource.data.members || request.auth.uid in request.resource.data.members) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'members',
            'memberJoinedAt',
            'lastMessage',
            'lastMessageTime'
          ]) &&
          hasTrustedJoinRequest(groupId)
        )
      );
      allow delete: if isAuth() && resource.data.adminUid == request.auth.uid;

      match /messages/{msgId} {
        allow read, write: if isAuth() && (
          request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.adminUid ||
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members
        );
        allow delete: if isAuth() && request.auth.uid == resource.data.senderUid;
      }
    }

    match /abuseReports/{docId} {
      allow create: if isAuth();
      allow read: if isAdmin();
    }
  }
}
